<p style="color: green"><%= notice %></p>

<% content_for :title, "Soadaa's Blog - Posts" %>

<h1 class="capitalize">
  <%= @category.pluralize %>
</h1>

<main id="posts">
  <% @posts.each do |post| %>
    <% cache post do %>
      <div class="post-div" data-controller="popover">
        <p class="capitalize">
          <%= time_tag post.created_at, post.created_at.strftime("%b %d, %Y") %>
          -
          <%= link_to post.title, post, 
              data: { action: "mouseenter->popover#show mouseleave->popover#hide" } %>
          <% if post.cover_image.attached? %>
            <template data-popover-target="content">
              <div class="post-popover" data-popover-target="card">
                <span><%= image_tag post.cover_image %></span>
              </div>
            </template>
          <% end %>
        </p>
      </div>
    <% end %>
  <% end %>

<% if @posts.first.nil? %>
  <p>No posts of this category type yet!</p>
<% end %>
</main>