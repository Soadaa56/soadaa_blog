<div class="post" id="<%= dom_id post %>">
  <div>
    <h1 class="capitalize">
      <%= post.title %>
    </h1>
  </div>
  
  <div>
    <h3><%= post.category.capitalize %></h3>
  </div>

  <div class="capitalize">
    <% if post.created_at == post.updated_at %>
      <%= @post.created_at.to_fs(:long) %>
    <% else %>
      <%= @post.created_at.to_fs(:long)%> (Last updated at: <%= @post.updated_at.to_fs(:long) %>)
    <% end %>
  </div>

  <% if post.cover_image.attached? %>
  <div>
    <%= post.cover_image %>
  </div>
  <% end %>

  <article class="post-body">
    <%= post.body %>
  </article>
</div>