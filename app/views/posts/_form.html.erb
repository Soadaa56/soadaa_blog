<%= form_with(model: post) do |form| %>
  <% if post.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(post.errors.count, "error") %> prohibited this post from being saved:</h2>

      <ul>
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, style: "display: block" %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :category, style: "display: block" %>
    <%= form.select :category, Post.categories.keys.map { |k| [k.humanize, k] } %>
  </div>

  <div>
    <%= form.label :published_at, "Publish at", style: "display: block" %>
    <%= form.datetime_local_field :published_at %>
  </div>

  <div>
    <%= form.label :body, style: "display: block" %>
    <%= form.textarea :body, rows: 22 %>
  </div>
  
  <div>
    <%= form.label :cover_image %>
    <%= form.file_field :cover_image %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
