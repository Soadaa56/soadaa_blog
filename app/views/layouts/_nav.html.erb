<nav id="nav-menu">
    <ul class="nav-list capitalize">
        <li><%= link_to "home", root_path %></li>
        <li><%= link_to "all posts", posts_path %></li>
        <li><%= link_to "blogs", posts_path(category: "blog") %></li>
        <li><%= link_to "reviews", posts_path(category: "review") %></li>
        <li><%= link_to "rankings", posts_path(category: "ranking") %></li>
        <li><%= link_to "impression", posts_path(category: "impression") %></li>
        <li><%= link_to "guides", posts_path(category: "guide") %></li>
    </ul>
    <div class="theme-menu" data-controller="theme">
        <%= image_tag "svg/sunray.svg", size: "36", 
            alt: "Sunray svg; icon for altering sites color theme.",
            class: "theme-icon",
            data: { action: "click->theme#menu" } %>
        <div class="menu-bg-overlay hidden"
            data-theme-target="selection"    
        ></div>
        <ul class="theme-dropdown-menu bold hidden capitalize" 
            data-theme-target="selection" 
            data-action="click->theme#selectTheme">

            <li data-theme-value="dark">dark</li>
            <li data-theme-value="light">light</li>
            <li data-theme-value="milk">milknthingzz</li>
            <li data-theme-value="neon">neon</li>
            <li data-theme-value="colorblind">colorblind</li>
        </ul>
    </div>
